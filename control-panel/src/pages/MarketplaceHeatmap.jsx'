import { MapContainer, TileLayer, Rectangle, Marker } from "react-leaflet";
import { useRef, useState, useEffect } from "react";

import "leaflet.heat";
import "leaflet-rotatedmarker";

import { getZones } from "../api/adminApi";
import {
  getLiquidityPressure,
  getActiveLessonsMap,
  getDispatchObservability,
  getLiquidityRisk,
  getInstructorDrift,
  getDispatchReplay,
  getInstructorLocations
} from "../api/adminApi";

import { usePolling } from "../hooks/usePolling";

import InstructorLayer from "../components/map/InstructorLayer";
import DemandHeatmap from "../components/map/DemandHeatmap";
import ActiveRoutesLayer from "../components/map/ActiveRoutesLayer";
import DispatchWaveLayer from "../components/map/DispatchWaveLayer";
import ReplayLayer from "../components/map/ReplayLayer";


/* ---------------------------------------------------
   HELPER FUNCTIONS
--------------------------------------------------- */

function interpolatePosition(start, end, progress) {
  const lat = start[0] + (end[0] - start[0]) * progress;
  const lng = start[1] + (end[1] - start[1]) * progress;
  return [lat, lng];
}

function getZoneCenter(zone) {
  const lat = (Number(zone.min_lat) + Number(zone.max_lat)) / 2;
  const lng = (Number(zone.min_lng) + Number(zone.max_lng)) / 2;
  return [lat, lng];
}

// Safe array helper (prevents crash if undefined)
function safeArray(arr) {
  return Array.isArray(arr) ? arr : [];
}


/* ---------------------------------------------------
   MAIN COMPONENT
--------------------------------------------------- */

export default function MarketplaceHeatmap() {

  const prevPositions = useRef({});

  /* ---------------------------------------------------
     STATE
  --------------------------------------------------- */

  const [dispatchWaves, setDispatchWaves] = useState([]);
  const [lessonId, setLessonId] = useState("");
  const [replayOffers, setReplayOffers] = useState([]);
  const [replayIndex, setReplayIndex] = useState(0);
  const [replayRunning, setReplayRunning] = useState(false);
  const [visibleWave, setVisibleWave] = useState(1);



  /* ---------------------------------------------------
     DATA (Polling)
  --------------------------------------------------- */

  const { data: zonesFromBackend } = usePolling(getZones, 10000);
  const { data: zones } = usePolling(getLiquidityPressure, 3000);
  const { data: instructors } = usePolling(getInstructorLocations, 2000);
  const { data: activeLessons } = usePolling(getActiveLessonsMap, 3000);
  const { data: liquidityRisk } = usePolling(getLiquidityRisk, 3000);
  const { data: drift } = usePolling(getInstructorDrift, 3000);

  console.log("DISPATCH WAVES:", dispatchWaves);

  
   /* ---------------- EFFECTS ---------------- */

  // ✅ STEP 2
  useEffect(() => {
    if (!dispatchWaves || dispatchWaves.length === 0) return;
    setVisibleWave(1);
  }, [dispatchWaves]);

  // ✅ STEP 3
  useEffect(() => {
    if (!dispatchWaves || dispatchWaves.length === 0) return;

    const maxWave = Math.max(...dispatchWaves.map(w => w.wave));
    let current = 1;

    const interval = setInterval(() => {
      current++;

      if (current > maxWave) {
        clearInterval(interval);
        return;
      }

      setVisibleWave(current);

    }, 1000);

    return () => clearInterval(interval);

  }, [dispatchWaves]);

  /* ---------------------------------------------------
     DERIVED DATA
  --------------------------------------------------- */

  const zonesMap = {};
  safeArray(zonesFromBackend).forEach(z => {
    zonesMap[z.id] = z;
  });

  // Sort waves safely
  const sortedWaves = [...safeArray(dispatchWaves)].sort(
  );


  /* ---------------------------------------------------
     ACTIONS
  --------------------------------------------------- */

  const loadReplay = async (lessonId) => {

  const replayData = await getDispatchReplay(lessonId);
   setReplayOffers(replayData);
   setReplayIndex(0);

  const wavesData = await getDispatchObservability(lessonId);
   setDispatchWaves(wavesData);

   };

  /* ---------------------------------------------------
     REPLAY ANIMATION
  --------------------------------------------------- */

  useEffect(() => {

    if (!replayRunning) return;

    const timer = setInterval(() => {

      setReplayIndex(prev => {

        if (prev >= replayOffers.length - 1) {
          setReplayRunning(false);
          return prev;
        }

        return prev + 1;

      });

    }, 1000);

    return () => clearInterval(timer);

  }, [replayRunning, replayOffers]);


  /* ---------------------------------------------------
     UI
  --------------------------------------------------- */

  return (

    <div>

  {/* Replay Controls */}
  <div style={{ marginBottom: "10px" }}>

    <input
      placeholder="lesson_request_id"
      value={lessonId}
      onChange={(e) => setLessonId(e.target.value)}
      style={{
        marginRight: "10px",
        padding: "5px",
        width: "300px"
      }}
    />

    <button
      onClick={() => {
        if (!lessonId) return;
        loadReplay(lessonId);
      }}
    >
      Load Replay
    </button>

    <button onClick={() => setReplayRunning(true)}>
      Start Replay
    </button>

  </div>


      <MapContainer
        center={[31.5204, 74.3587]}
        zoom={12}
        style={{ height: "600px", width: "100%" }}
      >

        <TileLayer url="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png" />

        {/* Heatmap */}
        <DemandHeatmap zones={zones} />

        {/* Active routes */}
        <ActiveRoutesLayer activeLessons={activeLessons} />

        {/* Dispatch waves */}
        <DispatchWaveLayer
          waves={sortedWaves}
          zonesMap={zonesMap}
        />

        {/* Replay */}
        <ReplayLayer
          offers={replayOffers}
          replayIndex={replayIndex}
        />

        {/* Instructors */}
        {safeArray(instructors).map((inst) => {

          let lat, lng;

          if (inst.lat && inst.lng) {
            lat = Number(inst.lat);
            lng = Number(inst.lng);
          } else {
            const zone = zonesMap[Number(inst.zone_id)];
            if (!zone) return null;

            lat =
              Number(zone.min_lat) +
              Math.random() * (zone.max_lat - zone.min_lat);

            lng =
              Number(zone.min_lng) +
              Math.random() * (zone.max_lng - zone.min_lng);
          }

          return (
            <Marker
              key={inst.instructor_id}
              position={[lat, lng]}
            />
          );

        })}

        {/* Zone boundaries */}
        {safeArray(zonesFromBackend).map((z) => {

          const bounds = [
            [Number(z.min_lat), Number(z.min_lng)],
            [Number(z.max_lat), Number(z.max_lng)]
          ];

          return (
            <Rectangle
              key={z.id}
              bounds={bounds}
              pathOptions={{ color: "blue", weight: 1 }}
            />
          );

        })}

      </MapContainer>

    </div>

  );

}
